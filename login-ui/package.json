{
	"name": "cpi-auth-login-ui",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 5053",
		"build": "vite build",
		"preview": "vite preview --port 5053",
		"start": "node build/index.js",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
